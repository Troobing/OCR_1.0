#   cp .env.example .env
#   修改 .env 中的 API Key 为自己的

# -------- LLM API 配置 --------
# API 地址（OpenAI 官方或第三方代理，必须以 /v1 结尾）
LLM_BASE_URL=https://api.uniapi.io/v1

# API Key
LLM_API_KEY=your-api-key-here

# 默认模型（必须支持视觉/图片识别，如 gpt-4o、gpt-4-vision-preview）
LLM_MODEL=gpt-4o

# -------- 上传限制 --------
# 单张图片最大上传大小（单位：MB）
MAX_UPLOAD_SIZE=20

# -------- 文件管理 --------
# 上传图片和生成文件的保留时间（单位：小时）
FILE_RETENTION_HOURS=12
